<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'Booking - RentNest' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    :root {
      --brand: #2163ea;
      --surface: #f5f7fb;
      --dark: #0f172a;
    }
    body {
      background: var(--surface);
      color: #1f2937;
    }
    .navbar {
      background: #fff;
      box-shadow: 0 1px 0 rgba(15, 23, 42, 0.06);
    }
    .brand-pill {
      width: 34px;
      height: 34px;
      border-radius: 10px;
      background: rgba(33, 99, 234, 0.1);
      color: var(--brand);
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    .mini-meta {
      font-size: 0.85rem;
      color: #6b7280;
    }
    .btn-brand {
      background: var(--brand);
      border-color: var(--brand);
    }
    .btn-brand:hover {
      background: #184fca;
      border-color: #184fca;
    }
    footer {
      background: #0b1328;
      color: #b6bfd6;
    }
    footer a {
      color: #d8e0f7;
      text-decoration: none;
    }
    footer a:hover {
      color: #fff;
    }
  </style>
</head>
<body>
<nav class="navbar navbar-expand-lg sticky-top">
  <div class="container">
    <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/">
      <span class="brand-pill"><i class="fa-solid fa-house-chimney-window"></i></span>
      <span>RentNest</span>
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="mainNav">
      <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
        <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
        <li class="nav-item"><a class="nav-link" href="/listings">All Listings</a></li>
      </ul>
    </div>
  </div>
</nav>

<section class="section-padding">
  <div class="container" style="max-width: 1100px;">
    <nav class="small text-muted mb-3">
      <a href="/" class="text-muted text-decoration-none">Home</a>
      <span class="mx-1">/</span>
      <a href="/listings" class="text-muted text-decoration-none">Listings</a>
      <span class="mx-1">/</span>
      <a href="/listings/<%= property.id %>" class="text-muted text-decoration-none"><%= property.name %></a>
      <span class="mx-1">/</span>
      <span>Booking</span>
    </nav>

    <h1 class="fw-bold mb-4">Complete Your Booking</h1>

    <% if (success) { %>
    <div class="alert alert-success"><%= success %></div>
    <% } %>

    <div class="row g-4 align-items-start">
      <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4">
          <div class="card-body p-4">
            <form method="POST" action="/listings/<%= property.id %>/booking">
              <h5 class="mb-3">Personal Information</h5>
              <div class="row g-3">
                <div class="col-md-6">
                  <label class="form-label">First Name *</label>
                  <input type="text" name="first_name" class="form-control">
                </div>
                <div class="col-md-6">
                  <label class="form-label">Last Name *</label>
                  <input type="text" name="last_name" class="form-control">
                </div>
                <div class="col-md-6">
                  <label class="form-label">Email *</label>
                  <input type="email" name="email" class="form-control">
                </div>
                <div class="col-md-6">
                  <label class="form-label">Phone Number *</label>
                  <input type="text" name="phone" class="form-control">
                </div>
              </div>

              <h5 class="mb-3 mt-4">Booking Details</h5>
              <div class="row g-3">
                <div class="col-md-6">
                  <label class="form-label">Rental Type *</label>
                  <select class="form-select" name="rental_type">
                    <option value="daily">Daily Rental</option>
                    <option value="monthly">Monthly Rental</option>
                  </select>
                </div>
                <div class="col-md-6">
                  <label class="form-label">Number of Guests *</label>
                  <select class="form-select" name="guests">
                    <% for (let i = 1; i <= 8; i++) { %>
                    <option value="<%= i %>"><%= i %> Guest<%= i > 1 ? 's' : '' %></option>
                    <% } %>
                  </select>
                </div>
                <div class="col-md-6">
                  <label class="form-label">Check-in Date *</label>
                  <input type="date" name="check_in" class="form-control">
                </div>
                <div class="col-md-6">
                  <label class="form-label">Check-out Date *</label>
                  <input type="date" name="check_out" class="form-control">
                </div>
                <div class="col-12">
                  <label class="form-label">Additional Message (Optional)</label>
                  <textarea name="message" class="form-control" rows="4" placeholder="Any special requests or questions..."></textarea>
                </div>
              </div>

              <button class="btn btn-brand text-white w-100 mt-4">Submit Booking Request</button>
            </form>
          </div>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4">
          <div class="card-body p-4">
            <h5 class="mb-3">Booking Summary</h5>
            <img src="<%= property.image %>" alt="<%= property.name %>" class="w-100 rounded-3 mb-3" style="height: 140px; object-fit: cover;">
            <h6 class="mb-1"><%= property.name %></h6>
            <p class="mini-meta mb-3"><%= property.location %></p>
            <div class="d-flex justify-content-between mb-2 small">
              <span>Daily Rate:</span>
              <strong>RM<%= property.daily_price %>/day</strong>
            </div>
            <div class="d-flex justify-content-between mb-3 small">
              <span>Monthly Rate:</span>
              <strong>RM<%= property.monthly_price.toLocaleString() %>/month</strong>
            </div>
            <p class="small text-muted mb-0">Final price is calculated based on selected dates and rental type.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<footer class="pt-5 pb-4">
  <div class="container">
    <div class="row g-4">
      <div class="col-md-3">
        <h6 class="text-white fw-bold">RentNest</h6>
        <p class="small mb-0">Find your perfect rental property for daily or monthly stays.</p>
      </div>
      <div class="col-6 col-md-3">
        <h6 class="text-white">Quick Links</h6>
        <div class="d-grid gap-1 small">
          <a href="/">Home</a>
          <a href="/listings">Listings</a>
          <a href="#">About Us</a>
          <a href="#">Contact</a>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <h6 class="text-white">Property Types</h6>
        <div class="d-grid gap-1 small">
          <a href="#">Apartments</a>
          <a href="#">Houses</a>
          <a href="#">Villas</a>
          <a href="#">Studios</a>
        </div>
      </div>
      <div class="col-md-3">
        <h6 class="text-white">Support</h6>
        <div class="d-grid gap-1 small">
          <a href="#">Help Center</a>
          <a href="#">Terms of Service</a>
          <a href="#">Privacy Policy</a>
          <a href="#">FAQs</a>
        </div>
      </div>
    </div>
    <hr class="border-secondary mt-4">
    <p class="small text-center mb-0">&copy; <%= new Date().getFullYear() %> RentNest. All rights reserved.</p>
  </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

