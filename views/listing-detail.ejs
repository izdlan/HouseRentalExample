<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || (property && property.name) || 'Property Details - RentNest' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    :root {
      --brand: #2163ea;
      --surface: #f5f7fb;
      --dark: #0f172a;
    }
    body {
      background: var(--surface);
      color: #1f2937;
    }
    .navbar {
      background: #fff;
      box-shadow: 0 1px 0 rgba(15, 23, 42, 0.06);
    }
    .brand-pill {
      width: 34px;
      height: 34px;
      border-radius: 10px;
      background: rgba(33, 99, 234, 0.1);
      color: var(--brand);
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    .mini-meta {
      font-size: 0.85rem;
      color: #6b7280;
    }
    .btn-brand {
      background: var(--brand);
      border-color: var(--brand);
    }
    .btn-brand:hover {
      background: #184fca;
      border-color: #184fca;
    }
    footer {
      background: #0b1328;
      color: #b6bfd6;
    }
    footer a {
      color: #d8e0f7;
      text-decoration: none;
    }
    footer a:hover {
      color: #fff;
    }
  </style>
</head>
<body>
<nav class="navbar navbar-expand-lg sticky-top">
  <div class="container">
    <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/">
      <span class="brand-pill"><i class="fa-solid fa-house-chimney-window"></i></span>
      <span>RentNest</span>
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="mainNav">
      <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
        <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
        <li class="nav-item"><a class="nav-link" href="/listings">All Listings</a></li>
      </ul>
    </div>
  </div>
</nav>

<section class="py-4">
  <div class="container">
    <nav class="small text-muted mb-3">
      <a href="/" class="text-muted text-decoration-none">Home</a>
      <span class="mx-1">/</span>
      <a href="/listings" class="text-muted text-decoration-none">Listings</a>
      <span class="mx-1">/</span>
      <span><%= property.name %></span>
    </nav>

    <img src="<%= property.image %>" class="w-100 rounded-4 mb-4" style="height: 380px; object-fit: cover;" alt="<%= property.name %>">

    <div class="row g-4 align-items-start">
      <div class="col-lg-7">
        <h1 class="fw-bold mb-2"><%= property.name %></h1>
        <p class="mb-3 text-muted"><i class="fa-solid fa-location-dot me-2"></i><%= property.location %></p>
        <div class="d-flex gap-4 border-top border-bottom py-3 mb-4 mini-meta">
          <span><i class="fa-solid fa-bed me-1"></i><%= property.bedrooms %> Bedrooms</span>
          <span><i class="fa-solid fa-bath me-1"></i><%= property.bathrooms %> Bathrooms</span>
          <span><i class="fa-solid fa-expand me-1"></i><%= property.size %> sqft</span>
        </div>

        <h4>About this property</h4>
        <p class="text-muted"><%= property.description %></p>

        <h4 class="mt-4">Amenities</h4>
        <div class="row g-2 mini-meta">
          <div class="col-sm-4"><i class="fa-solid fa-wifi me-2"></i>WiFi</div>
          <div class="col-sm-4"><i class="fa-solid fa-snowflake me-2"></i>Air Conditioning</div>
          <div class="col-sm-4"><i class="fa-solid fa-square-parking me-2"></i>Parking</div>
          <div class="col-sm-4"><i class="fa-solid fa-utensils me-2"></i>Kitchen</div>
          <div class="col-sm-4"><i class="fa-solid fa-shirt me-2"></i>Washer/Dryer</div>
          <div class="col-sm-4"><i class="fa-solid fa-bicycle me-2"></i>Bike Storage</div>
        </div>
      </div>

      <div class="col-lg-5">
        <div class="card border-0 shadow-sm rounded-4">
          <div class="card-body p-4">
            <h2 class="fw-bold mb-0">RM<%= property.daily_price %> <small class="text-muted fs-6 fw-normal">/ day</small></h2>
            <h4 class="mb-3">RM<%= property.monthly_price.toLocaleString() %> <small class="text-muted fs-6 fw-normal">/ month</small></h4>
            <p class="small text-muted mb-3">Choose your rental type and travel dates to continue booking.</p>

            <form action="/listings/<%= property.id %>/booking" method="GET">
              <div class="mb-3">
                <label class="form-label">Rental Type</label>
                <select class="form-select" name="rental_type">
                  <option value="daily">Daily Rental</option>
                  <option value="monthly">Monthly Rental</option>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label">Check-in Date</label>
                <input type="date" class="form-control" name="check_in">
              </div>
              <div class="mb-3">
                <label class="form-label">Check-out Date</label>
                <input type="date" class="form-control" name="check_out">
              </div>
              <button class="btn btn-brand w-100 text-white">Book Now</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<footer class="pt-5 pb-4">
  <div class="container">
    <div class="row g-4">
      <div class="col-md-3">
        <h6 class="text-white fw-bold">RentNest</h6>
        <p class="small mb-0">Find your perfect rental property for daily or monthly stays.</p>
      </div>
      <div class="col-6 col-md-3">
        <h6 class="text-white">Quick Links</h6>
        <div class="d-grid gap-1 small">
          <a href="/">Home</a>
          <a href="/listings">Listings</a>
          <a href="#">About Us</a>
          <a href="#">Contact</a>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <h6 class="text-white">Property Types</h6>
        <div class="d-grid gap-1 small">
          <a href="#">Apartments</a>
          <a href="#">Houses</a>
          <a href="#">Villas</a>
          <a href="#">Studios</a>
        </div>
      </div>
      <div class="col-md-3">
        <h6 class="text-white">Support</h6>
        <div class="d-grid gap-1 small">
          <a href="#">Help Center</a>
          <a href="#">Terms of Service</a>
          <a href="#">Privacy Policy</a>
          <a href="#">FAQs</a>
        </div>
      </div>
    </div>
    <hr class="border-secondary mt-4">
    <p class="small text-center mb-0">&copy; <%= new Date().getFullYear() %> RentNest. All rights reserved.</p>
  </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

