<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'RentNest - House Rental' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    :root {
      --brand: #2163ea;
      --surface: #f5f7fb;
      --dark: #0f172a;
    }
    body {
      background: var(--surface);
      color: #1f2937;
    }
    .navbar {
      background: #fff;
      box-shadow: 0 1px 0 rgba(15, 23, 42, 0.06);
    }
    .brand-pill {
      width: 34px;
      height: 34px;
      border-radius: 10px;
      background: rgba(33, 99, 234, 0.1);
      color: var(--brand);
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    .hero-banner {
      background: linear-gradient(160deg, #1f5ce0 0%, #1f68ee 60%, #2b75fc 100%);
    }
    .section-padding {
      padding: 4.5rem 0;
    }
    .property-card {
      border: 0;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 8px 20px rgba(15, 23, 42, 0.08);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      height: 100%;
    }
    .property-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 16px 30px rgba(15, 23, 42, 0.15);
    }
    .property-card img {
      height: 170px;
      object-fit: cover;
    }
    .availability-tag {
      position: absolute;
      top: 10px;
      left: 10px;
      background: #16c660;
      color: #fff;
      border-radius: 12px;
      padding: 0.2rem 0.6rem;
      font-size: 0.75rem;
      font-weight: 600;
    }
    .daily-tag {
      position: absolute;
      top: 10px;
      right: 10px;
      background: rgba(255, 255, 255, 0.95);
      border-radius: 12px;
      padding: 0.2rem 0.6rem;
      font-size: 0.75rem;
      font-weight: 600;
    }
    .btn-brand {
      background: var(--brand);
      border-color: var(--brand);
    }
    .btn-brand:hover {
      background: #184fca;
      border-color: #184fca;
    }
    .mini-meta {
      font-size: 0.85rem;
      color: #6b7280;
    }
    .cta-band {
      background: #2163ea;
      color: #fff;
    }
    footer {
      background: #0b1328;
      color: #b6bfd6;
    }
    footer a {
      color: #d8e0f7;
      text-decoration: none;
    }
    footer a:hover {
      color: #fff;
    }
  </style>
</head>
<body>
<nav class="navbar navbar-expand-lg sticky-top">
  <div class="container">
    <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/">
      <span class="brand-pill"><i class="fa-solid fa-house-chimney-window"></i></span>
      <span>RentNest</span>
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="mainNav">
      <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
        <li class="nav-item"><a class="nav-link active fw-semibold" href="/">Home</a></li>
        <li class="nav-item"><a class="nav-link" href="/listings">All Listings</a></li>
      </ul>
    </div>
  </div>
</nav>

<section class="hero-banner py-5 text-white">
  <div class="container py-4 text-center">
    <h1 class="display-5 fw-bold">Find Your Perfect Rental Home</h1>
    <p class="lead mb-4">Daily or monthly rentals for every lifestyle and budget</p>
    <form action="/listings" class="bg-white rounded-3 p-3 row g-2 align-items-center shadow mx-auto" style="max-width: 980px;">
      <div class="col-md-4">
        <input type="text" class="form-control border-0 bg-light" placeholder="Location">
      </div>
      <div class="col-md-4">
        <input type="text" class="form-control border-0 bg-light" placeholder="Check-in Date">
      </div>
      <div class="col-md-4 d-grid">
        <button class="btn btn-brand text-white"><i class="fa-solid fa-magnifying-glass me-2"></i>Search</button>
      </div>
    </form>
  </div>
</section>

<section class="section-padding bg-white">
  <div class="container">
    <div class="row g-4 text-center">
      <div class="col-md-4">
        <div class="mb-3 fs-4 text-primary"><i class="fa-solid fa-magnifying-glass"></i></div>
        <h5>Easy Search</h5>
        <p class="text-muted">Find your ideal property with our advanced search filters.</p>
      </div>
      <div class="col-md-4">
        <div class="mb-3 fs-4 text-primary"><i class="fa-regular fa-calendar-check"></i></div>
        <h5>Flexible Booking</h5>
        <p class="text-muted">Choose daily or monthly rentals based on your needs.</p>
      </div>
      <div class="col-md-4">
        <div class="mb-3 fs-4 text-primary"><i class="fa-solid fa-location-dot"></i></div>
        <h5>Prime Locations</h5>
        <p class="text-muted">Properties in the best neighborhoods across the country.</p>
      </div>
    </div>
  </div>
</section>

<section class="section-padding">
  <div class="container">
    <div class="d-flex justify-content-between align-items-end mb-4">
      <div>
        <h2 class="fw-bold mb-1">Featured Properties</h2>
        <p class="text-muted mb-0">Discover our handpicked selection of premium rentals</p>
      </div>
      <a href="/listings" class="text-decoration-none">View All <i class="fa-solid fa-arrow-right-long"></i></a>
    </div>
    <div class="row g-4">
      <% properties.slice(0, 6).forEach(function(property) { %>
      <div class="col-md-6 col-lg-4">
        <div class="card property-card">
          <div class="position-relative">
            <img src="<%= property.image %>" alt="<%= property.name %>" class="w-100">
            <span class="availability-tag">Available</span>
            <span class="daily-tag">RM<%= property.daily_price %>/day</span>
          </div>
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-center">
              <h5 class="card-title mb-0"><%= property.name %></h5>
              <small class="text-warning"><i class="fa-solid fa-star"></i> <%= property.rating %></small>
            </div>
            <p class="mini-meta mb-2 mt-2"><i class="fa-solid fa-location-dot me-1"></i><%= property.location %></p>
            <p class="mini-meta mb-3">
              <i class="fa-solid fa-bed me-1"></i><%= property.bedrooms %>
              <span class="mx-2">|</span>
              <i class="fa-solid fa-bath me-1"></i><%= property.bathrooms %>
              <span class="mx-2">|</span>
              <i class="fa-solid fa-expand me-1"></i><%= property.size %> sqft
            </p>
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <small class="text-muted d-block">Monthly</small>
                <strong>RM<%= property.monthly_price %></strong>
              </div>
              <a href="/listings/<%= property.id %>" class="btn btn-brand btn-sm text-white">View Details</a>
            </div>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<section class="cta-band py-5">
  <div class="container text-center">
    <h2 class="fw-bold">Ready to Find Your Perfect Home?</h2>
    <p class="lead mb-4">Browse thousands of properties available for daily and monthly rentals</p>
    <a href="/listings" class="btn btn-light px-4">Explore All Properties</a>
  </div>
</section>

<footer class="pt-5 pb-4">
  <div class="container">
    <div class="row g-4">
      <div class="col-md-3">
        <h6 class="text-white fw-bold">RentNest</h6>
        <p class="small mb-0">Find your perfect rental property for daily or monthly stays.</p>
      </div>
      <div class="col-6 col-md-3">
        <h6 class="text-white">Quick Links</h6>
        <div class="d-grid gap-1 small">
          <a href="/">Home</a>
          <a href="/listings">Listings</a>
          <a href="#">About Us</a>
          <a href="#">Contact</a>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <h6 class="text-white">Property Types</h6>
        <div class="d-grid gap-1 small">
          <a href="#">Apartments</a>
          <a href="#">Houses</a>
          <a href="#">Villas</a>
          <a href="#">Studios</a>
        </div>
      </div>
      <div class="col-md-3">
        <h6 class="text-white">Support</h6>
        <div class="d-grid gap-1 small">
          <a href="#">Help Center</a>
          <a href="#">Terms of Service</a>
          <a href="#">Privacy Policy</a>
          <a href="#">FAQs</a>
        </div>
      </div>
    </div>
    <hr class="border-secondary mt-4">
    <p class="small text-center mb-0">&copy; <%= new Date().getFullYear() %> RentNest. All rights reserved.</p>
  </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

