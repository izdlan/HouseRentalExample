<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'All Properties - RentNest' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    :root {
      --brand: #2163ea;
      --surface: #f5f7fb;
      --dark: #0f172a;
    }
    body {
      background: var(--surface);
      color: #1f2937;
    }
    .navbar {
      background: #fff;
      box-shadow: 0 1px 0 rgba(15, 23, 42, 0.06);
    }
    .brand-pill {
      width: 34px;
      height: 34px;
      border-radius: 10px;
      background: rgba(33, 99, 234, 0.1);
      color: var(--brand);
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    .section-padding {
      padding: 4.5rem 0;
    }
    .property-card {
      border: 0;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 8px 20px rgba(15, 23, 42, 0.08);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      height: 100%;
    }
    .property-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 16px 30px rgba(15, 23, 42, 0.15);
    }
    .property-card img {
      height: 170px;
      object-fit: cover;
    }
    .availability-tag {
      position: absolute;
      top: 10px;
      left: 10px;
      background: #16c660;
      color: #fff;
      border-radius: 12px;
      padding: 0.2rem 0.6rem;
      font-size: 0.75rem;
      font-weight: 600;
    }
    .daily-tag {
      position: absolute;
      top: 10px;
      right: 10px;
      background: rgba(255, 255, 255, 0.95);
      border-radius: 12px;
      padding: 0.2rem 0.6rem;
      font-size: 0.75rem;
      font-weight: 600;
    }
    .btn-brand {
      background: var(--brand);
      border-color: var(--brand);
    }
    .btn-brand:hover {
      background: #184fca;
      border-color: #184fca;
    }
    .mini-meta {
      font-size: 0.85rem;
      color: #6b7280;
    }
    footer {
      background: #0b1328;
      color: #b6bfd6;
    }
    footer a {
      color: #d8e0f7;
      text-decoration: none;
    }
    footer a:hover {
      color: #fff;
    }
  </style>
</head>
<body>
<nav class="navbar navbar-expand-lg sticky-top">
  <div class="container">
    <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/">
      <span class="brand-pill"><i class="fa-solid fa-house-chimney-window"></i></span>
      <span>RentNest</span>
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="mainNav">
      <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
        <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
        <li class="nav-item"><a class="nav-link active fw-semibold" href="/listings">All Listings</a></li>
      </ul>
    </div>
  </div>
</nav>

<section class="section-padding">
  <div class="container">
    <h1 class="fw-bold mb-0">All Properties</h1>
    <p class="text-muted"><%= properties.length %> properties available</p>

    <div class="row g-4 align-items-start">
      <div class="col-lg-3">
        <div class="card border-0 shadow-sm rounded-3">
          <div class="card-body">
            <h5 class="mb-3"><i class="fa-solid fa-sliders me-2"></i>Filters</h5>
            <div class="mb-3">
              <label class="form-label">Property Type</label>
              <select class="form-select">
                <option>All Types</option>
                <option>Apartment</option>
                <option>House</option>
                <option>Villa</option>
                <option>Studio</option>
              </select>
            </div>
            <div class="mb-3">
              <label class="form-label">Daily Price Range</label>
              <select class="form-select">
                <option>All Prices</option>
                <option>Below RM100/day</option>
                <option>RM100 - RM200/day</option>
                <option>Above RM200/day</option>
              </select>
            </div>
            <div class="mb-4">
              <label class="form-label">Bedrooms</label>
              <select class="form-select">
                <option>Any</option>
                <option>1+</option>
                <option>2+</option>
                <option>3+</option>
                <option>4+</option>
              </select>
            </div>
            <button class="btn btn-outline-secondary w-100">Clear Filters</button>
          </div>
        </div>
      </div>

      <div class="col-lg-9">
        <div class="row g-4">
          <% properties.forEach(function(property) { %>
          <div class="col-md-6 col-xl-4">
            <div class="card property-card">
              <div class="position-relative">
                <img src="<%= property.image %>" alt="<%= property.name %>" class="w-100">
                <span class="availability-tag">Available</span>
                <span class="daily-tag">RM<%= property.daily_price %>/day</span>
              </div>
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                  <h5 class="card-title mb-0"><%= property.name %></h5>
                  <small class="text-warning"><i class="fa-solid fa-star"></i> <%= property.rating %></small>
                </div>
                <p class="mini-meta mb-2 mt-2"><i class="fa-solid fa-location-dot me-1"></i><%= property.location %></p>
                <p class="mini-meta mb-3">
                  <i class="fa-solid fa-bed me-1"></i><%= property.bedrooms %>
                  <span class="mx-2">|</span>
                  <i class="fa-solid fa-bath me-1"></i><%= property.bathrooms %>
                  <span class="mx-2">|</span>
                  <i class="fa-solid fa-expand me-1"></i><%= property.size %> sqft
                </p>
                <div class="d-flex justify-content-between align-items-center">
                  <div>
                    <small class="text-muted d-block">Monthly</small>
                    <strong>RM<%= property.monthly_price %></strong>
                  </div>
                  <a href="/listings/<%= property.id %>" class="btn btn-brand btn-sm text-white">View Details</a>
                </div>
              </div>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
</section>

<footer class="pt-5 pb-4">
  <div class="container">
    <div class="row g-4">
      <div class="col-md-3">
        <h6 class="text-white fw-bold">RentNest</h6>
        <p class="small mb-0">Find your perfect rental property for daily or monthly stays.</p>
      </div>
      <div class="col-6 col-md-3">
        <h6 class="text-white">Quick Links</h6>
        <div class="d-grid gap-1 small">
          <a href="/">Home</a>
          <a href="/listings">Listings</a>
          <a href="#">About Us</a>
          <a href="#">Contact</a>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <h6 class="text-white">Property Types</h6>
        <div class="d-grid gap-1 small">
          <a href="#">Apartments</a>
          <a href="#">Houses</a>
          <a href="#">Villas</a>
          <a href="#">Studios</a>
        </div>
      </div>
      <div class="col-md-3">
        <h6 class="text-white">Support</h6>
        <div class="d-grid gap-1 small">
          <a href="#">Help Center</a>
          <a href="#">Terms of Service</a>
          <a href="#">Privacy Policy</a>
          <a href="#">FAQs</a>
        </div>
      </div>
    </div>
    <hr class="border-secondary mt-4">
    <p class="small text-center mb-0">&copy; <%= new Date().getFullYear() %> RentNest. All rights reserved.</p>
  </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

